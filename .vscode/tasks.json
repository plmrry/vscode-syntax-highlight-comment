{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "pnpm: build",
			"type": "shell",
			"command": "pnpm run build",
			"group": "build",
			"problemMatcher": "$tsc"
		},
		{
			"label": "pnpm: watch",
			"type": "shell",
			"command": "pnpm run watch",
			"isBackground": true,
			"problemMatcher": "$tsc-watch",
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		}
	]
}

{
  "name": "vscode-syntax-highlight-comment",
  "displayName": "Syntax Highlight Comment",
  "icon": "icon.png",
  "version": "2026.2.280054",
  "description": "Enable syntax highlighting in JS/TS template literals using comment markers like /** css */.",
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "vscode",
    "template literal",
    "javascript",
    "typescript",
    "syntax highlighting",
    "css",
    "html",
    "shell"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/plmrry/vscode-syntax-highlight-comment"
  },
  "license": "CC0-1.0",
  "author": "paul-murray",
  "publisher": "paul-murray",
  "type": "module",
  "main": "./ts-out/extension.js",
  "types": "./ts-out/extension.d.ts",
  "files": [
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md",
    "icon.png",
    "src",
    "package.json",
    "syntaxes",
    "ts-out",
    "tsconfig.json"
  ],
  "scripts": {
    "biome": "biome check --write --unsafe .",
    "precompile": "pnpm run biome",
    "compile": "tsgo --build",
    "prebuild": "node ./scripts/build-grammar.mjs",
    "build": "pnpm run compile",
    "prepackage": "pnpm run build",
    "package": "vsce package",
    "prepublish": "pnpm run package",
    "publish": "vsce publish patch"
  },
  "contributes": {
    "commands": [
      {
        "command": "syntaxHighlightComment.showSupportedMarkers",
        "title": "Syntax Highlight Comment: Show Supported Markers"
      }
    ],
    "grammars": [
      {
        "scopeName": "syntax-highlight-comment.injection",
        "path": "./syntaxes/syntax-highlight-comment.tmLanguage.json",
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.ts",
          "source.tsx"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.syntax-highlight-comment.css": "css",
          "meta.embedded.block.syntax-highlight-comment.html": "html",
          "meta.embedded.block.syntax-highlight-comment.shell": "shellscript"
        },
        "tokenTypes": {
          "meta.embedded.block.syntax-highlight-comment.css": "other",
          "meta.embedded.block.syntax-highlight-comment.html": "other",
          "meta.embedded.block.syntax-highlight-comment.shell": "other"
        }
      }
    ]
  },
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onCommand:syntaxHighlightComment.showSupportedMarkers"
  ],
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/node": "24",
    "@types/vscode": "^1.109",
    "@vscode/vsce": "latest",
    "@typescript/native-preview": "latest"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "24.x",
    "vscode": "^1.109.5"
  },
  "pricing": "Free",
  "vsce": {
    "out": "vsix-file",
    "githubBranch": "main",
    "noDependencies": true
  }
}
